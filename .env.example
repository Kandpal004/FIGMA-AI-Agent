# =============================================================================
# Ecommerce AI Design Director — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Every variable here maps 1:1 to a field in packages/core/src/core/config.py.
# =============================================================================

# ---------- Application ----------
# Runtime environment: local | staging | production
APP_ENV=local
# Human-readable service name (appears in logs & health payloads)
APP_NAME="Ecommerce AI Design Director"
# DEBUG toggles verbose logging & echoes SQL. Keep false in production.
APP_DEBUG=true
# API bind host/port for uvicorn
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins (the React console).
API_CORS_ORIGINS=http://localhost:5173

# ---------- Security ----------
# 32+ char random secret used to sign session/JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# ---------- PostgreSQL ----------
# Async DSN (SQLAlchemy + asyncpg driver).
POSTGRES_DSN=postgresql+asyncpg://ddirector:ddirector@localhost:5432/ddirector
# Connection pool sizing
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ---------- Redis ----------
# Used for the async job queue (ARQ) and ephemeral run state / caching.
REDIS_DSN=redis://localhost:6379/0

# ---------- Qdrant (vector memory) ----------
QDRANT_URL=http://localhost:6333
# Leave blank for local; required for Qdrant Cloud.
QDRANT_API_KEY=
# Default collection for the Memory Agent's design knowledge.
QDRANT_COLLECTION=design_memory

# ---------- LLM (Anthropic Claude) ----------
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Default model for heavy reasoning agents (Creative Director, UX Architect...).
LLM_DEFAULT_MODEL=claude-opus-4-8
# Cheaper/faster model for mechanical agents (formatting, validation).
LLM_FAST_MODEL=claude-haiku-4-5-20251001
# Global ceiling on output tokens per single agent call.
LLM_MAX_OUTPUT_TOKENS=8192
# Request timeout (seconds) and retry attempts for transient failures.
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ---------- Figma via MCP ----------
# Command the MCP client launches to reach the Figma MCP server, plus token.
# Left blank in Phase 1 (the Tool Layer is stubbed until Phase 3).
FIGMA_MCP_COMMAND=
FIGMA_ACCESS_TOKEN=

# ---------- Commerce platforms (stubbed until later phases) ----------
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_STORE_DOMAIN=
MAGENTO_BASE_URL=
MAGENTO_ACCESS_TOKEN=

# ---------- Observability ----------
# text | json  — json is recommended for production log aggregation.
LOG_FORMAT=text
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
